{
    "version": 2,
    "builds": [
        {
            "src": "api/app.py",
            "use": "@vercel/python"
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/app.py"
        }
    ],
    "functions": {
        "api/app.py": {
            "maxDuration": 300
        }
    }
}
